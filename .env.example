# Copy to `.env` and fill in the values. Never commit `.env` itself.
# Add every new env var here (without its value) when you add one.

# ─── DNMS (HRMS) careers API ────────────────────────────────────────────────
# Read-only key for the published careers tree.
# SERVER-ONLY: the endpoint allows any origin, so a browser-side fetch would
# publish this key to anyone viewing source. Never rename this to NEXT_PUBLIC_*.
DNMS_CAREERS_API_KEY=

# Separate WRITE key for posting applications back to DNMS. Distinct from the
# read key above (the read key is rejected with 401) so it can be rotated on its
# own - it can write applicant PII. SERVER-ONLY: the applications endpoint sends
# no CORS headers at all, so a browser call fails by design.
DNMS_CAREERS_WRITE_API_KEY=

# ─── Sanity CMS ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# Server-only token for authenticated/draft reads.
SANITY_API_TOKEN=

# ─── Transactional email (careers + contact forms) ──────────────────────────
GMAIL_USER=
# Gmail app password, not the account password.
GMAIL_APP_PASSWORD=

# ─── Analytics ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_TRACKING_ID=
