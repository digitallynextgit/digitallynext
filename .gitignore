# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# this repo uses pnpm (pnpm-lock.yaml); ignore the npm lockfile so it can't return
package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# generated SEO audit artifacts
/screenshots

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template of required var names carries no values, so it is committed.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
